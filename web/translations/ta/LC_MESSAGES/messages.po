#: web/b3desk/__init__.py:329 web/b3desk/endpoints/meeting_files.py:123
#: web/b3desk/endpoints/meeting_files.py:182
#: web/b3desk/endpoints/meeting_files.py:287
#: web/b3desk/endpoints/meeting_files.py:477
msgid ""
"Le service de fichiers est temporairement indisponible. Veuillez réessayer "
"dans quelques minutes."
msgstr ""
"கோப்பு பணி தற்காலிகமாக கிடைக்கவில்லை. சில நிமிடங்களில் மீண்டும் முயற்சிக்கவும்."

#: web/b3desk/forms.py:43
msgid "Lien web du fichier à ajouter"
msgstr "சேர்க்க வேண்டிய கோப்பின் இணைய இணைப்பு"

#: web/b3desk/forms.py:44
msgid "Le lien web à entrer doit permettre de télécharger un fichier"
msgstr ""
"உள்ளிட வேண்டிய இணைய இணைப்பு, கோப்பைப் பதிவிறக்க உங்களை அனுமதிக்க வேண்டும்"

#: web/b3desk/forms.py:47
msgid "Le texte est trop long"
msgstr "உரை மிக நீளமாக உள்ளது"

#: web/b3desk/forms.py:51 web/b3desk/forms.py:106
#: web/b3desk/templates/admin/meeting_infos.html:235
msgid "Salle d'attente"
msgstr "காத்திருப்பு அறை"

#: web/b3desk/forms.py:53 web/b3desk/forms.py:108
msgid ""
"Placer les participants dans une salle d'attente lorsqu'ils rejoignent la "
"réunion. L'organisateur ou le modérateur devra les accepter individuellement."
msgstr ""
"கூட்டத்தில் சேரும்போது பங்கேற்பாளர்களை காத்திருப்பு அறையில் வைக்கவும். அமைப்பாளர் அல்லது "
"மதிப்பீட்டாளர் தனித்தனியாக அவற்றை ஏற்றுக்கொள்ள வேண்டும்."

#: web/b3desk/forms.py:63
msgid "Nom de la réunion"
msgstr "கூட்டத்தின் பெயர்"

#: web/b3desk/forms.py:66
msgid ""
"Vous ne pourrez plus changer ce titre une fois la salle créée. Ce nom est "
"visible des participants"
msgstr ""
"அறையை உருவாக்கியவுடன் இந்த தலைப்பை மாற்ற முடியாது. இந்தப் பெயர் பங்கேற்பாளர்களுக்குத் தெரியும்"

#: web/b3desk/forms.py:69
msgid "Ma réunion"
msgstr "கூட்டம்"

#: web/b3desk/forms.py:77 web/b3desk/templates/admin/meeting_infos.html:148
msgid "Texte de bienvenue"
msgstr "வரவேற்பு உரை"

#: web/b3desk/forms.py:79
msgid ""
"Ce texte apparait comme message de bienvenue sur le tchat public. 150 "
"caractères max."
msgstr ""
"இந்த உரை பொது அரட்டையில் வரவேற்பு செய்தியாக தோன்றும். அதிகபட்சம் 150 எழுத்துகள்."

#: web/b3desk/forms.py:82
#, python-format
msgid "Bienvenue dans cette réunion %(meeting_name)s."
msgstr "இந்த %(meeting_name)s மீட்டிங்குக்கு வரவேற்கிறோம்."

#: web/b3desk/forms.py:89 web/b3desk/templates/admin/meeting_infos.html:123
msgid "Nombre maximal de participants"
msgstr "பங்கேற்பாளர்களின் அதிகபட்ச பெயர்"

#: web/b3desk/forms.py:90
msgid "Limitez vos salons à 350 personnes pour plus de confort."
msgstr "அதிக வசதிக்காக உங்கள் ஓய்வறைகளை 350 பேருக்கு வரம்பிடவும்."

#: web/b3desk/forms.py:94 web/b3desk/templates/admin/meeting_infos.html:140
msgid "Durée maximale (minutes)"
msgstr "அதிகபட்ச கால அளவு (நிமிடங்கள்)"

#: web/b3desk/forms.py:96
msgid ""
"A l'issue de cette durée la réunion stoppe automatiquement. 1h = 60, 2h = "
"120, 3h = 180, 4h = 240."
msgstr ""
"இந்த காலகட்டத்தின் முடிவில் சந்திப்பு தானாகவே நின்றுவிடும். 1h = 60, 2h = 120, 3h = 180, "
"4h = 240."

#: web/b3desk/forms.py:113 web/b3desk/templates/admin/meeting_infos.html:179
msgid "Caméras visibles par les modérateurs uniquement"
msgstr "மதிப்பீட்டாளர்களுக்கு மட்டுமே கேமராக்கள் தெரியும்"

#: web/b3desk/forms.py:115
msgid ""
"Seuls vous et les modérateurs pouvez voir les caméras des autres "
"participants quand cette option est activée."
msgstr ""
"இந்த விருப்பம் இயக்கப்பட்டிருக்கும் போது, மற்ற பங்கேற்பாளர்களின் கேமராக்களை நீங்களும் "
"மதிப்பீட்டாளர்களும் மட்டுமே பார்க்க முடியும்."

#: web/b3desk/forms.py:120 web/b3desk/templates/admin/meeting_infos.html:187
msgid "Participants muets à leur arrivée"
msgstr "பங்கேற்பாளர்கள் வந்தவுடன் ஒலியடக்கிறார்கள்"

#: web/b3desk/forms.py:122
msgid ""
"Vous pouvez choisir de faire arriver les participants dans la salle avec "
"leur micro fermé, pour un démarrage de réunion plus calme."
msgstr ""
"கூட்டத்தை அமைதியாகத் தொடங்க, பங்கேற்பாளர்கள் மைக்ரோஃபோன்களை மூடிய நிலையில் அறைக்குள் "
"நுழைவதை நீங்கள் தேர்வு செய்யலாம்."

#: web/b3desk/forms.py:127 web/b3desk/templates/admin/meeting_infos.html:195
msgid "Caméras des participants"
msgstr "பங்கேற்பாளர் கேமராக்கள்"

#: web/b3desk/forms.py:129
msgid ""
"Vous pouvez autoriser ou interdire l'ouverture de la caméra des participants."
msgstr ""
"பங்கேற்பாளரின் கேமராவைத் திறப்பதை நீங்கள் அனுமதிக்கலாம் அல்லது தடை செய்யலாம்."

#: web/b3desk/forms.py:135 web/b3desk/templates/admin/meeting_infos.html:203
msgid "Micros des participants"
msgstr "பங்கேற்பாளர் மைக்ரோஃபோன்கள்"

#: web/b3desk/forms.py:137
msgid ""
"Vous pouvez autoriser ou interdire l'ouverture du microphone des "
"participants."
msgstr ""
"பங்கேற்பாளர்கள் மைக்ரோஃபோனைத் திறப்பதை நீங்கள் அனுமதிக்கலாம் அல்லது தடை செய்யலாம்."

#: web/b3desk/forms.py:143 web/b3desk/templates/admin/meeting_infos.html:211
msgid "Discussions privées"
msgstr "தனிப்பட்ட அரட்டைகள்"

#: web/b3desk/forms.py:148 web/b3desk/templates/admin/meeting_infos.html:219
msgid "Discussion publique (tchat)"
msgstr "பொது விவாதம் (அரட்டை)"

#: web/b3desk/forms.py:153 web/b3desk/templates/admin/meeting_infos.html:227
msgid "Prise de note collaborative"
msgstr "கூட்டு குறிப்பு எடுத்தல்"

#: web/b3desk/forms.py:158 web/b3desk/templates/admin/meeting_infos.html:156
msgid "Message à l'attention des modérateurs"
msgstr "மதிப்பீட்டாளர்களுக்கு செய்தி"

#: web/b3desk/forms.py:159
msgid "150 caractères max"
msgstr "அதிகபட்சம் 150 எழுத்துகள்"

#: web/b3desk/forms.py:160 web/b3desk/models/meetings.py:338
msgid "Bienvenue aux modérateurs"
msgstr "மதிப்பீட்டாளர்களை வரவேற்கிறோம்"

#: web/b3desk/forms.py:164
msgid "Le message est trop long"
msgstr "செய்தி மிக நீளமாக உள்ளது"

#: web/b3desk/forms.py:171 web/b3desk/templates/admin/meeting_infos.html:131
msgid "Url de redirection après la réunion"
msgstr "சந்திப்புக்குப் பிறகு முகவரி ஐத் திருப்பிவிடவும்"

#: web/b3desk/forms.py:178
msgid "Renouveler le lien modérateur"
msgstr "மதிப்பீட்டாளர் இணைப்பைப் புதுப்பிக்கவும்"

#: web/b3desk/forms.py:180 web/b3desk/forms.py:189
msgid "Ce code vous permet si vous le changez de bloquer les anciens liens."
msgstr ""
"நீங்கள் அதை மாற்றினால், பழைய இணைப்புகளைத் தடுக்க இந்தக் குறியீடு உங்களை அனுமதிக்கிறது."

#: web/b3desk/forms.py:187
msgid "Renouveler le lien participants"
msgstr "பங்கேற்பாளர் இணைப்பைப் புதுப்பிக்கவும்"

#: web/b3desk/forms.py:196 web/b3desk/templates/admin/meeting_infos.html:107
msgid "PIN"
msgstr "முள்"

#: web/b3desk/forms.py:198
msgid "Code PIN pour rejoindre la réunion par téléphone (9 chiffres)"
msgstr "ஃபோன் மூலம் மீட்டிங்கில் சேர்வதற்கான பின் குறியீடு (9 இலக்கங்கள்)"

#: web/b3desk/forms.py:204
msgid "Entez un PIN de 9 chiffres"
msgstr "9 இலக்க பின்னை உள்ளிடவும்"

#: web/b3desk/forms.py:208
msgid "Le code PIN est composé de chiffres uniquement"
msgstr "பின் குறியீடு எண்களால் மட்டுமே ஆனது"

#: web/b3desk/forms.py:211
msgid "Le premier chiffre doit être différent de 0"
msgstr "முதல் இலக்கமானது 0 இலிருந்து வேறுபட்டிருக்க வேண்டும்"

#: web/b3desk/forms.py:217
msgid "Code de connexion"
msgstr "உள்நுழைவு குறியீடு"

#: web/b3desk/forms.py:219
#, python-format
msgid "Code de connexion pour rejoindre la réunion %(sip)s"
msgstr "மீட்டிங்கில் சேர்வதற்கான இணைப்புக் குறியீடு %(sip)s"

#: web/b3desk/forms.py:220
msgid "(utilisé dans le lien SIP)"
msgstr "(SIP இணைப்பில் பயன்படுத்தப்பட்டது)"

#: web/b3desk/forms.py:234 web/b3desk/templates/admin/meeting_infos.html:172
msgid "Enregistrement manuel"
msgstr "கைமுறையாக பதிவு செய்தல்"

#: web/b3desk/forms.py:236
msgid ""
"Vous pouvez lancer ou arrêter à tout moment l'enregistrement de la salle."
msgstr ""
"நீங்கள் எந்த நேரத்திலும் அறையைப் பதிவுசெய்யத் தொடங்கலாம் அல்லது நிறுத்தலாம்."

#: web/b3desk/forms.py:241 web/b3desk/templates/admin/meeting_infos.html:164
msgid "Enregistrement automatique"
msgstr "தானாக சேமிக்கவும்"

#: web/b3desk/forms.py:243
msgid ""
"L'enregistrement démarre automatiquement à l'ouverture de la salle et "
"s'arrête à sa fermeture."
msgstr ""
"அறை திறக்கும் போது பதிவு தானாகவே தொடங்கும் மற்றும் மூடும் போது நிறுத்தப்படும்."

#: web/b3desk/forms.py:251
msgid "Nom de l'enregistrement"
msgstr "பதிவு பெயர்"

#: web/b3desk/forms.py:257
msgid "Ajout d'utilisateur"
msgstr "பயனரைச் சேர்க்கவும்"

#: web/b3desk/forms.py:267 web/b3desk/templates/admin/users.html:19
msgid "Rechercher un utilisateur"
msgstr "ஒரு பயனரைத் தேடுங்கள்"

#: web/b3desk/forms.py:274 web/b3desk/templates/admin/meetings.html:19
msgid "Rechercher une réunion"
msgstr "சந்திப்பைக் கண்டறியவும்"

#: web/b3desk/settings.py:660 web/b3desk/templates/meeting/list.html:4
msgid "Mes salles de réunion"
msgstr "எனது சந்திப்பு அறைகள்"

#: web/b3desk/settings.py:664
msgid "Invitation à une réunion en ligne immédiate du Webinaire de l’Etat"
msgstr "மாநில வெபினாரின் உடனடி நிகழ்நிலை கூட்டத்திற்கான அழைப்பு"

#: web/b3desk/settings.py:677
msgid "Réunion improvisée"
msgstr "திடீர் சந்திப்பு"

#: web/b3desk/settings.py:680
msgid " Lien Modérateur  "
msgstr " மதிப்பீட்டாளர் இணைப்பு  "

#: web/b3desk/settings.py:683
msgid " Lien Participant  "
msgstr " லீன் பங்கேற்பாளர்  "

#: web/b3desk/settings.py:687
msgid ""
"Bienvenue aux modérateurs. Pour inviter quelqu'un à cette réunion, envoyez-"
"lui l'un de ces liens :"
msgstr ""
"மதிப்பீட்டாளர்களை வரவேற்கிறோம். இந்தக் கூட்டத்திற்கு யாரையாவது அழைக்க, பின்வரும் இணைப்புகளில் "
"ஒன்றை அவர்களுக்கு அனுப்பவும்:"

#: web/b3desk/endpoints/join.py:68
msgid "Aucune réunion ne correspond à ces paramètres"
msgstr "இந்த அமைப்புகளுடன் எந்த சந்திப்புகளும் பொருந்தவில்லை"

#: web/b3desk/endpoints/join.py:81 web/b3desk/endpoints/join.py:147
#: web/b3desk/endpoints/join.py:152 web/b3desk/endpoints/join.py:209
#: web/b3desk/endpoints/join.py:217
msgid "Le lien d'invitation que vous avez utilisé est invalide."
msgstr "நீங்கள் பயன்படுத்திய அழைப்பு இணைப்பு தவறானது."

#: web/b3desk/endpoints/join.py:184
msgid "Lien invalide"
msgstr "தவறான இணைப்பு"

#: web/b3desk/endpoints/join.py:320
msgid "Le captcha saisi est erroné"
msgstr "உள்ளிட்ட கேப்ட்சா தவறானது"

#: web/b3desk/endpoints/join.py:325
msgid "Le code de connexion saisi est erroné"
msgstr "உள்ளிட்ட இணைப்புக் குறியீடு தவறானது"

#: web/b3desk/endpoints/meeting_files.py:55
msgid "Vous ne pouvez pas modifier cet élément"
msgstr "இந்த உருப்படியை நீங்கள் திருத்த முடியாது"

#: web/b3desk/endpoints/meeting_files.py:169
#: web/b3desk/endpoints/meeting_files.py:250
#, python-brace-format
msgid "Fichier {title} trop volumineux, ne pas dépasser {max_size}Mo"
msgstr "கோப்பு {title} மிகவும் பெரியது, {max_size}MB ஐ விட அதிகமாக இல்லை"

#: web/b3desk/endpoints/meeting_files.py:212
#: web/b3desk/endpoints/meeting_files.py:271
#: web/b3desk/endpoints/meeting_files.py:318
#: web/b3desk/endpoints/meeting_files.py:357
msgid "Le fichier a déjà été mis en ligne"
msgstr "கோப்பு ஏற்கனவே பதிவேற்றப்பட்டது"

#: web/b3desk/endpoints/meeting_files.py:235
#: web/b3desk/endpoints/meeting_files.py:242
#, python-brace-format
msgid "Fichier {title} non disponible, veuillez vérifier l'URL proposée"
msgstr ""
"{title} கோப்பு கிடைக்கவில்லை, பரிந்துரைக்கப்பட்ட முகவரி ஐச் சரிபார்க்கவும்"

#: web/b3desk/endpoints/meeting_files.py:297
#, python-brace-format
msgid "Fichier {path} trop volumineux, ne pas dépasser {max_size}Mo"
msgstr "கோப்பு {path} மிகவும் பெரியது, {max_size}MB ஐ விட அதிகமாக இல்லை"

#: web/b3desk/endpoints/meeting_files.py:365
msgid "Erreur lors de l'écriture du fichier sur le disque"
msgstr "கோப்பை வட்டுக்கு எழுதுவதில் பிழை"

#: web/b3desk/endpoints/meeting_files.py:378
msgid "Type de fichier non autorisé"
msgstr "அங்கீகரிக்கப்படாத கோப்பு வகை"

#: web/b3desk/endpoints/meeting_files.py:382
msgid "Erreur de taille du fichier"
msgstr "கோப்பு அளவு பிழை"

